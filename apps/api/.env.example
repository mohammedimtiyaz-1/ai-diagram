# Environment
APP_ENV=development

# CORS (comma-separated for multiple origins)
CORS_ORIGINS=http://localhost:3000

# AI Provider
OPENAI_API_KEY=your_openai_api_key_here

# Per-API Timeouts (seconds)
ENHANCE_TIMEOUT_SECONDS=30
REFINE_TIMEOUT_SECONDS=45
ANALYZE_TIMEOUT_SECONDS=60

# Per-API Rate Limits (requests per minute)
ENHANCE_RATE_LIMIT=10
REFINE_RATE_LIMIT=8
ANALYZE_RATE_LIMIT=5

# AI Models per use-case
# Fast/cheap models for short prompt tasks
ENHANCE_MODEL=gpt-4o-mini
REFINE_MODEL=gpt-4o-mini
INTENT_MODEL=gpt-4o-mini
GENERATION_MODEL=gpt-4o-mini
# Powerful model for evidence-based codebase analysis
ANALYZE_MODEL=gpt-4o
CODEBASE_GENERATION_MODEL=gpt-4o
